#!/usr/bin/env bash
# Run Storybook locally (no Docker). Installs npm dependencies if needed,
# starts the dev server, and opens the browser when it is ready.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# Install dependencies if node_modules is missing
if [ ! -d node_modules ]; then
  echo "node_modules not found - running npm install..."
  npm install
fi

# Cross-platform browser opener
open_browser() {
  local url="$1"
  if command -v xdg-open &>/dev/null; then
    xdg-open "$url" &>/dev/null &
  elif command -v open &>/dev/null; then
    open "$url" &>/dev/null &
  elif command -v wslview &>/dev/null; then
    wslview "$url" &>/dev/null &
  fi
}

# Poll until the server responds, then open the browser
wait_and_open() {
  local url="$1"
  local max_wait=60
  local count=0
  (
    while [ $count -lt $max_wait ]; do
      if curl -s -o /dev/null "$url" 2>/dev/null; then
        open_browser "$url"
        exit 0
      fi
      sleep 1
      count=$((count + 1))
    done
    echo "Warning: Storybook did not respond within ${max_wait}s - open $url manually" >&2
  ) &
}

echo "Starting Storybook on http://localhost:6006"
wait_and_open "http://localhost:6006"
npx storybook dev --port 6006 --no-open
