#!/bin/bash
# Compare current chart implementation against reference PDFs
# Usage: ./scripts/compare-charts [age-band]
# age-band: 0-11m, 1-4y, 5-12y, 13y (default: all)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REFERENCE_DIR="$PROJECT_ROOT/reference-sources/images"
OUTPUT_DIR="$PROJECT_ROOT/test-output/screenshots"

# Ensure output directory exists
mkdir -p "$OUTPUT_DIR"

# Function to take screenshot of current implementation
take_screenshot() {
    local age_band="$1"
    echo "Taking screenshot for age band: $age_band"
    
    # TODO: Use puppeteer/playwright to:
    # 1. Load http://localhost:8765
    # 2. Set data.js to use specified age band
    # 3. Take screenshot
    # 4. Save to $OUTPUT_DIR/current-$age_band.png
    
    echo "Screenshot would be saved to: $OUTPUT_DIR/current-$age_band.png"
}

# Function to compare images side-by-side
compare_images() {
    local age_band="$1"
    local reference="$REFERENCE_DIR/chart-$age_band-1.png"
    local current="$OUTPUT_DIR/current-$age_band.png"
    local output="$OUTPUT_DIR/comparison-$age_band.png"
    
    if [ -f "$reference" ] && [ -f "$current" ]; then
        echo "Comparing: $age_band"
        # Use imagemagick to create side-by-side comparison
        if command -v convert &> /dev/null; then
            convert "$reference" "$current" +append "$output"
            echo "Comparison saved to: $output"
        else
            echo "ImageMagick not installed - skipping visual diff"
        fi
    else
        echo "Missing images for comparison: $age_band"
    fi
}

# Main
AGE_BAND="${1:-all}"

if [ "$AGE_BAND" = "all" ]; then
    for band in "0-11-months" "1-4-years" "5-12-years" "13-years"; do
        take_screenshot "$band"
        compare_images "$band"
    done
else
    take_screenshot "$AGE_BAND"
    compare_images "$AGE_BAND"
fi

echo "Done! Check $OUTPUT_DIR for results"
