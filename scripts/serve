#!/usr/bin/env bash
# Serve the chart-ui app locally.
# Usage: scripts/serve [port]
# Default port: 3000

set -euo pipefail

PORT="${1:-3000}"
DIR="$(cd "$(dirname "$0")/.." && pwd)/apps/chart-ui"

if [ ! -d "$DIR" ]; then
  echo "Error: $DIR not found" >&2
  exit 1
fi

echo "Serving $DIR on http://0.0.0.0:$PORT"

if command -v python3 &>/dev/null; then
  python3 -m http.server "$PORT" --directory "$DIR"
elif command -v python &>/dev/null; then
  cd "$DIR" && python -m SimpleHTTPServer "$PORT"
elif command -v npx &>/dev/null; then
  npx --yes serve "$DIR" -l "$PORT"
else
  echo "Error: no suitable server found (python3, python, or npx required)" >&2
  exit 1
fi
